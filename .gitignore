# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/
**/build/
!gradle/wrapper/gradle-wrapper.jar

# Local configuration file (sdk path, etc)
local.properties
gradle-daemon-jvm.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log
.kotlin/errors/

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
!.idea/.gitignore
!.idea/vcs.xml
!.idea/codeStyles/
!.idea/codeStyles/codeStyleConfig.xml

# Keystore files
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild/
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# Freeline
freeline.py
freeline/
freeline_project_description.json

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# Version control
vcs.xml

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/

# Android Profiling
*.hprof

# macOS
.DS_Store

# Native libraries - Exclude most, but allow library module .so files
**/*.so
**/*.a
!libuvc/src/main/jniLibs/**/*.so
!libnative/src/main/jniLibs/**/*.so

# NDI SDK files (must be added manually per NDI_SETUP.md)
ndi/src/main/jniLibs/
